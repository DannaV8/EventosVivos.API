TestResults/
coverage/
*.coveragexml

# Publish output
publish/
out/

# Local dev config
**/Properties/launchSettings.json

# Logs
logs/
*.log

# Environment / secrets
appsettings.Development.json
*.env
.env

# OS
Thumbs.db
.DS_Store
